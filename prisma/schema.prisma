generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  COMUM
  ADMIN
}

model User {
  id            Int      @id @default(autoincrement())
  nome          String
  cargo         String? // exibição apenas — permissão vem de `role`
  email         String   @unique
  senhaHash     String
  role          Role     @default(COMUM)
  fotoPerfilUrl String?
  criadoEm      DateTime @default(now())

  eventosCriados     Evento[]
  registrosCriados   Registro[]
  devolucoesCriadas  Devolucao[]
  radiosCriados      Radio[]
  recebedoresCriados Recebedor[]
  auditLogs          AuditLog[]
}

// Imutável; sobrevive à deleção do ator (FK SetNull + snapshot do nome).
model AuditLog {
  id         Int      @id @default(autoincrement())
  actor      User?    @relation(fields: [actorId], references: [id], onDelete: SetNull)
  actorId    Int?
  actorNome  String
  acao       String
  entidade   String
  entidadeId Int
  resumo     String
  detalhes   Json?
  criadoEm   DateTime @default(now())

  @@index([criadoEm])
  @@index([actorId])
  @@index([entidade, entidadeId])
}

model Evento {
  id          Int        @id @default(autoincrement())
  nome        String
  dataInicio  DateTime
  dataFim     DateTime
  criadoPor   User       @relation(fields: [criadoPorId], references: [id])
  criadoPorId Int
  criadoEm    DateTime   @default(now())
  registros   Registro[]
}

model Radio {
  id               Int        @id @default(autoincrement())
  numeroPatrimonio String     @unique
  numeroSerie      String // sem @unique: typos históricos do fabricante são reais
  marca            String
  modelo           String
  acessorios       String? // texto livre
  criadoPor        User       @relation(fields: [criadoPorId], references: [id])
  criadoPorId      Int
  criadoEm         DateTime   @default(now())
  atualizadoEm     DateTime   @updatedAt
  registros        Registro[]
}

// Cadastro reutilizável entre eventos. Não confundir com Registro (o empréstimo em si).
model Recebedor {
  id           Int        @id @default(autoincrement())
  nome         String
  rg           String // sem @unique: typos históricos são reais
  departamento String
  cargo        String
  foneContato  String
  criadoPor    User       @relation(fields: [criadoPorId], references: [id])
  criadoPorId  Int
  criadoEm     DateTime   @default(now())
  atualizadoEm DateTime   @updatedAt
  registros    Registro[]

  @@index([nome])
}

// Check-out de rádio. Fotos (RG + rádio) são prova do ato no momento da entrega.
model Registro {
  id                Int        @id @default(autoincrement())
  evento            Evento     @relation(fields: [eventoId], references: [id])
  eventoId          Int
  radio             Radio      @relation(fields: [radioId], references: [id])
  radioId           Int
  recebedor         Recebedor  @relation(fields: [recebedorId], references: [id])
  recebedorId       Int
  urlFotoRg         String
  urlFotoRadioSaida String
  observacao        String?
  criadoPor         User       @relation(fields: [criadoPorId], references: [id])
  criadoPorId       Int
  criadoEm          DateTime   @default(now())
  devolucao         Devolucao?
}

model Devolucao {
  id                    Int      @id @default(autoincrement())
  registro              Registro @relation(fields: [registroId], references: [id])
  registroId            Int      @unique
  urlFotoRadioDevolucao String
  possuiAvaria          Boolean  @default(false)
  observacao            String?
  devolvidoPor          String? // null = mesmo recebedor do Registro
  criadoPor             User     @relation(fields: [criadoPorId], references: [id])
  criadoPorId           Int
  criadoEm              DateTime @default(now())
}
